# clay-knowledge prototype — task runner
# Run from the prototype/ directory.

# default: show available recipes
default:
    @just --list

# ── dev server (Leptos SSR + hydration + tantivy search) ──────────────────────
dev:
    cargo leptos watch

# fast server-side type check
check:
    cargo check -p clay-app --no-default-features --features ssr

# ── static-site pipeline (-> site/, deployable to GitHub Pages) ───────────────

# 1. extract IR from the archived site (needs ../data/digitalfire-archive)
extract src="../data/digitalfire-archive" out="data/ir":
    cargo run -p clay-extract --release -- {{src}} {{out}}

# 2. web-optimize + rename + remap images (-> data/web/, the committed content)
images:
    cargo run -p clay-images --release -- data/ir ../data/digitalfire-archive/media data/web

# 3. render the static site from data/web + 4. build the Pagefind search index
site:
    cargo run -p clay-ssg --release
    npx -y pagefind@latest --site site

# full pipeline from the ground-truth archive (extract -> images -> site)
static: extract images site

# preview the built static site
serve-static port="8790":
    python3 -m http.server {{port}} --directory site
